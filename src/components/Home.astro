---
// src/pages/[lang]/index.astro
import Layout from '../layouts/Layout.astro';
import { BASE_PATH } from '../config.js';
import { translations } from '../i18n/ui.js';

const { lang } = Astro.props;
const t = { ...translations['fr'], ...(translations[lang] || {}) };

const title = t['home.meta.title'];
const description = t['home.meta.description'];
const image = t['home.meta.image'];

// Automatically find all testimonials and distribute them left-to-right across 3 columns
const testimonialKeys = Object.keys(t)
  .filter(key => key.startsWith('testimonials.') && key.endsWith('.text'))
  .map(key => key.split('.')[1])
  .sort((a, b) => parseInt(a) - parseInt(b));

const testimonials = testimonialKeys.map((key, index) => ({
  key,
  col: (index % 3) + 1
}));

// FAQ data
const faqs = [
  { q: t['faq.q1'], a: t['faq.a1'] },
  { q: t['faq.q2'], a: t['faq.a2'] },
  { q: t['faq.q3'], a: t['faq.a3'] },
  { q: t['faq.q4'], a: t['faq.a4'] },
  { q: t['faq.q5'], a: t['faq.a5'] },
  { q: t['faq.q6'], a: t['faq.a6'] },
];

const googleSvg = `<svg viewBox="0 0 24 24" class="source-icon">
  <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
  <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
  <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z"/>
  <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
</svg>`;

const arrowSvg = `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
  <line x1="5" y1="12" x2="19" y2="12"></line>
  <polyline points="12 5 19 12 12 19"></polyline>
</svg>`;
const currentMonth = new Date().toLocaleString(lang, { month: 'long' });
---

<Layout lang={lang} title={title} description={description} image={image}>

  <!-- HERO SECTION -->
  <section class="hero">
    <div class="container mt-5">
      <div class="row">
        <div class="col-12 col-lg-9">
          <span class="section-tag opacity-75 mb-4">{t['home.banner.callout']}</span>
          <h1>{t['home.banner.title,part1']} <span class="accent-highlight">{t['home.banner.title,part2']}</span></h1>
          <p class="fs-5 opacity-75 mb-4" set:html={t['home.banner.paragraph']}></p>
          <div class="d-flex flex-column gap-3 align-items-start mt-4">
            <a href={`${BASE_PATH}/${lang}/contact/`} class="btn btn-primary">{t['home.banner.cta']}</a>
            <span class="text-sm-clamp opacity-75">{t['home.banner.cta-incentive'].replace('{month}', currentMonth)}</span>
          </div>
        </div>
      </div>
    </div>

    <!-- LOGO TICKER -->
    <div class="ticker-wrap">
      <div class="container text-start fs-sm letter-spacing-2 text-uppercase opacity-50 mb-4 fw-semibold">
        <span set:html={t['home.advised']}></span>
      </div>
      <div class="ticker" id="logoTicker">        <img src="https://via.placeholder.com/150x40.png?text=Logo+Client+1" alt={t['home.logo.client_1.alt']} />
        <img src="https://via.placeholder.com/150x40.png?text=Logo+Client+2" alt={t['home.logo.client_2.alt']} />
        <img src="https://via.placeholder.com/150x40.png?text=Logo+Client+3" alt={t['home.logo.client_3.alt']} />
        <img src="https://via.placeholder.com/150x40.png?text=Logo+Client+4" alt={t['home.logo.client_4.alt']} />
        <img src="https://via.placeholder.com/150x40.png?text=Logo+Client+5" alt={t['home.logo.client_5.alt']} />
        <img src="https://via.placeholder.com/150x40.png?text=Logo+Client+6" alt={t['home.logo.client_6.alt']} />
        <img src="https://via.placeholder.com/150x40.png?text=Logo+Client+7" alt={t['home.logo.client_7.alt']} />
        <img src="https://via.placeholder.com/150x40.png?text=Logo+Client+8" alt={t['home.logo.client_8.alt']} />
        <img src="https://via.placeholder.com/150x40.png?text=Logo+Client+9" alt={t['home.logo.client_9.alt']} />
      </div>
    </div>
  </section>

  <!-- PROBLEM & FRICTION SECTION -->
  <section id="problem" class="section-light p-0 overflow-hidden mt-0">
    <div class="split-section">
      <div class="split-left pt-5rem">
        <div class="split-content-left">
          <span class="section-tag section-tag-teal small mb-3 d-block">{t['problem.tag']}</span>
          <h2 class="split-title mt-0">
            {t['problem.title.part1']}
            <span class="text-silver">{t['problem.title.part2']}</span>
            {t['problem.title.part3']}
          </h2>
          <p class="split-desc">
            {t['problem.subtitle']}
          </p>
        </div>
      </div>
      <div class="split-right pt-5rem">
        <div class="split-content-right">
          <div class="numbered-list">
            <div class="numbered-item">
              <div class="item-number fs-lg-icon fw-bolder">✕</div>
              <div class="item-content">
                <h3>{t['problem.friction.1.title']}</h3>
                <p>{t['problem.friction.1']}</p>
              </div>
            </div>
            <div class="numbered-item">
              <div class="item-number fs-lg-icon fw-bolder">✕</div>
              <div class="item-content">
                <h3>{t['problem.friction.2.title']}</h3>
                <p>{t['problem.friction.2']}</p>
              </div>
            </div>
            <div class="numbered-item">
              <div class="item-number fs-lg-icon fw-bolder">✕</div>
              <div class="item-content">
                <h3>{t['problem.friction.3.title']}</h3>
                <p>{t['problem.friction.3']}</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="split-section">
      <div class="split-left pt-custom-4">
        <div class="split-content-left">
          <img src="https://via.placeholder.com/800x600.png?text=IMAGE+PLACEHOLDER" alt={t['problem.friction.image.alt']} class="w-100 rounded-3 object-fit-cover placeholder-img" />
        </div>
      </div>
      <div class="split-right pt-custom-4">
        <div class="split-content-right">
          <h2 class="problem-friction-title fw-bolder text-dark mb-4">
            {t['problem.friction.title']}
          </h2>
          <div class="friction-desc-wrapper fs-1-15 lh-lg text-secondary">
            <p class="m-0">{t['problem.friction.p1']}</p>
            <p class="m-0">{t['problem.friction.p2']}</p>
            <h4 class="friction-cost text-danger mt-3 fst-italic fw-semibold">
              {t['problem.friction.cost']}
            </h4>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ABOUT SECTION -->
  <section id="about">
    <div class="container">
      <span class="section-tag-red">{t['about.tag']}</span>
      <h2 class="display-5 mb-5 w-100">
        {t['about.title']}
      </h2>

      <div class="about-grid">
        <div class="about-image-column">
          <img src="https://via.placeholder.com/800x800.png?text=IMAGE+PLACEHOLDER" alt={t['about.founder.image.alt']} class="w-100 rounded-3 object-fit-cover placeholder-img" />
          <div class="founder-info">
            <h4>{t['about.founder_name']}</h4>
            <p>{t['about.role']}</p>
            <img src="https://via.placeholder.com/200x30.png?text=Éducation" alt={t['about.logo.education.alt']} class="mt-4 opacity-75" />
          </div>
        </div>

        <div class="pt-3">
          <h3 class="fs-2 mb-4">{t['about.hello']}</h3>
          <div class="d-flex flex-column gap-4 fs-5 opacity-75 lh-base">
            <p>{t['about.desc.p1']}</p>
            <p>{t['about.desc.p2']}</p>
          </div>
          <div class="mini-ticker opacity-75">
            <span>{t['about.seen']}</span>
            <img src="https://via.placeholder.com/80x30.png?text=Logo" alt={t['about.logo.seen_1.alt']} class="logo-placeholder" />
            <img src="https://via.placeholder.com/80x30.png?text=Logo" alt={t['about.logo.seen_2.alt']} class="logo-placeholder" />
            <img src="https://via.placeholder.com/80x30.png?text=Logo" alt={t['about.logo.seen_3.alt']} class="logo-placeholder" />
            <img src="https://via.placeholder.com/80x30.png?text=Logo" alt={t['about.logo.seen_4.alt']} class="logo-placeholder" />
            <img src="https://via.placeholder.com/80x30.png?text=Logo" alt={t['about.logo.seen_5.alt']} class="logo-placeholder" />
          </div>
        </div>
      </div>

      <!--<div class="approach-text" style="margin-top: 6rem; margin-bottom: 4rem; max-width: 900px;">
        <h3 style="margin-bottom: 2.5rem;">
          {t['approach.title']}
        </h3>
        <p style="font-size: 1.2rem; opacity: 0.9; line-height: 1.6;">
          {lang === 'fr'
            ? <>{t['approach.desc.p1']}<strong>{t['approach.desc.p2']}</strong>{t['approach.desc.p3']}</>
            : <>{t['approach.desc.p1']}<strong>{t['approach.desc.p2']}</strong>{t['approach.desc.p3']}</>
          }
        </p>
      </div>-->
      <!--<div class="grid-3">
        <div class="expertise-card">
          <h3>{t['expertise.improve.title']}</h3>
          <p>{t['expertise.improve.desc']}</p>
        </div>
        <div class="expertise-card">
          <h3>{t['expertise.clarify.title']}</h3>
          <p>{t['expertise.clarify.desc']}</p>
        </div>
        <div class="expertise-card">
          <h3>{t['expertise.simplify.title']}</h3>
          <p>{t['expertise.simplify.desc']}</p>
        </div>
      </div>-->
    </div>
  </section>

  <!-- SERVICES SECTION -->
  <section id="services" class="section-light">
    <div class="container">
      <!--<div class="toptal-badge">
        <span class="badge-label">{t['services.toptal.badge']}</span>
        <span class="badge-value">Top 3%</span>
        <span class="badge-sub">{t['services.toptal.sub']}</span>
      </div>-->
      <h2 class="mb-5">
        {t['services.title']}
      </h2>

      <div class="grid-2 services-grid">
        <a href={`${BASE_PATH}/${lang}/industrie-4-0/`} class="card card-minimal">
          <h3>{t['services.service_1.title']}</h3>
          <p>{t['services.service_1.desc']}</p>
          <div class="card-arrow" set:html={arrowSvg}></div>
        </a>
        <a href={`${BASE_PATH}/${lang}/gestion-des-operations/`} class="card card-minimal">
          <h3>{t['services.service_2.title']}</h3>
          <p>{t['services.service_2.desc']}</p>
          <div class="card-arrow" set:html={arrowSvg}></div>
        </a>
        <a href={`${BASE_PATH}/${lang}/lean-management/`} class="card card-minimal">
          <h3>{t['services.service_3.title']}</h3>
          <p>{t['services.service_3.desc']}</p>
          <div class="card-arrow" set:html={arrowSvg}></div>
        </a>
        <a href={`${BASE_PATH}/${lang}/leadership-industriel/`} class="card card-minimal">
          <h3>{t['services.service_4.title']}</h3>
          <p>{t['services.service_4.desc']}</p>
          <div class="card-arrow" set:html={arrowSvg}></div>
        </a>
      </div>
    </div>
  </section>

  <!-- PERFORMANCE & STATS SECTION -->
  <section id="performance" class="performance-section">
    <div class="container">
      <div class="performance-header">
        <h2>{t['performance.title']}</h2>
        <p>{t['performance.desc']}</p>
        <h3 class="mt-4 mb-3 fs-2">{t['performance.guineapig.title']}</h3>
        <p>{t['performance.guineapig.desc']}</p>
      </div>
      <div class="stats-grid">
        <div class="stat-card">
          <h4>{t['stats.conversion.title']}</h4>
          <div class="stat-number" data-target="16">0x</div>
          <p>{t['stats.conversion.desc']}</p>
        </div>
        <div class="stat-card">
          <h4>{t['stats.businesses.title']}</h4>
          <div class="stat-number" data-target="500">0+</div>
          <p>{t['stats.businesses.desc']}</p>
        </div>
        <div class="stat-card">
          <h4>{t['stats.markets.title']}</h4>
          <div class="stat-number" data-target="30">0+</div>
          <p>{t['stats.markets.desc']}</p>
        </div>
        <div class="stat-card">
          <h4>{t['stats.reach.title']}</h4>
          <div class="stat-number" data-target="6">0+</div>
          <p>{t['stats.reach.desc']}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- PORTFOLIO SECTION -->
  <section id="portfolio" class="section-light">
    <div class="container text-center">
      <h2 class="display-5 mb-5">
        {t['portfolio.title']}
      </h2>
      <div class="grid-2">
        {[
          "ASSASSIN'S CREED ODYSSEY", "WARNER BROS. APP", "MARVEL APP",
          "MUSÉE DE LA CIVILISATION", "CLINICAL TRIAL PHARMY (+48%)",
          "WIZARDS OF THE COAST", "SPIN MASTER", "TROUVEUNSTAGE.COM"
        ].map(label => (
          <div class="portfolio-item">
            <div class="placeholder-img"><span class="portfolio-label">{label}</span></div>
          </div>
        ))}
      </div>
      <div class="my-5 py-3">
        <h3 class="fs-3 opacity-75 fw-semibold">
          {t['portfolio.subtitle']}
        </h3>
      </div>
      <div class="awards-ticker">
        <span class="opacity-50 text-uppercase small">{t['portfolio.recognized']}</span>
        <div class="awards-logos">
          <span>OCTAS</span><span>osentreprendre</span><span>Gartner</span><span>AWWWWARDS</span>
        </div>
      </div>
      <div class="mt-5">
        <a href={`${BASE_PATH}/${lang}/contact/`} class="btn btn-danger px-5 py-3">
          {t['portfolio.cta']}
        </a>
      </div>
    </div>
  </section>

  <!-- QUALIFICATION SECTION -->
  <section id="qualification" class="section-light">
    <div class="container">
      <h2 class="w-75 mb-5">
        <>{t['qualification.title'].split('PAS')[0]}<em>PAS</em>{t['qualification.title'].split('PAS')[1]}</>
      </h2>
      <div class="grid-2 align-items-start gap-5 mb-4">
        <div>
          <h3 class="fs-3 mb-4 text-dark">
            {t['qualification.yes.title']}
          </h3>
          <ul class="qualification-list qualification-list--yes">
            <li>{t['qualification.yes.1']}</li>
            <li>{t['qualification.yes.2']}</li>
            <li>{t['qualification.yes.3']}</li>
          </ul>
        </div>
        <div>
          <h3 class="fs-3 mb-4 text-dark">
            {t['qualification.no.title']}
          </h3>
          <ul class="qualification-list qualification-list--no">
            <li>{t['qualification.no.1']}</li>
            <li>{t['qualification.no.2']}</li>
            <li>{t['qualification.no.3']}</li>
          </ul>
        </div>
      </div>
      <p class="opacity-75">
        <>{t['qualification.footer.part1']}<strong>{t['qualification.footer.part2']}<a href={`${BASE_PATH}/${lang}/contact/`} class="text-dark text-decoration-underline fw-bold">{t['qualification.footer.part3']}</a></strong></>
      </p>
    </div>
  </section>

  <!-- TESTIMONIALS SECTION -->
  <section id="testimonials">
    <div class="container">
      <h2 class="text-center mb-5">{t['testimonials.title']}</h2>
      <div class="masonry-grid">
        {[1, 2, 3].map(col => (
          <div class="masonry-col">
            {testimonials.filter(tm => tm.col === col).map(tm => (
              <div class="card testimonial-card">
                <div class="testimonial-source" set:html={googleSvg}></div>
                <p class="testimonial-text">{t[`testimonials.${tm.key}.text`]}</p>
                <button class="read-more-btn" data-more={t['testimonials.more']} data-less={t['testimonials.less']}>{t['testimonials.more']}</button>
                <div class="testimonial-footer">
                  <div class="testimonial-author">{t[`testimonials.${tm.key}.author`]}</div>
                  <div class="testimonial-role">{t[`testimonials.${tm.key}.role`]}</div>
                </div>
              </div>
            ))}
          </div>
        ))}
      </div>
      <div class="text-center mt-5">
        <a href={`${BASE_PATH}/${lang}/contact/`} class="btn btn-dashed">
          <span class="btn-dashed-icon">+</span> {t['testimonials.cta']}
        </a>
      </div>
    </div>
  </section>

  <!-- FAQ SECTION -->
  <section id="faq" class="section-light">
    <div class="container grid-2 align-items-start">
      <div>
        <span class="section-tag">{t['faq.tag']}</span>
        <h2 class="mb-4">{t['faq.title']}</h2>
        <p class="fs-5 opacity-75">{t['faq.subtitle']}</p>
      </div>
      <div class="faq-list">
        {faqs.map(faq => (
          <div class="faq-item">
            <button class="faq-question">
              <span set:html={faq.q}></span>
              <span class="faq-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12h14"/></svg></span>
            </button>
            <div class="faq-answer">
              <p set:html={faq.a}></p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FINAL CTA SECTION -->
  <section id="contact" class="cta-section">
    <div class="container grid-2 cta-content-wrapper">
      <div class="cta-left">
        <span class="section-tag section-tag-teal small mb-3 d-block">{t['cta.tag']}</span>
        <h2 class="display-3 mb-5 w-75 lh-sm" set:html={t['cta.title']}></h2>
        <a href={`${BASE_PATH}/${lang}/contact/`} class="btn-sharp">
          {t['cta.button']} <span class="btn-arrow" set:html={arrowSvg}></span>
        </a>
      </div>
      <div class="cta-right align-self-end pb-4">
        <p class="fs-5 opacity-75 lh-base w-75 ms-auto text-start">{t['cta.subtitle']}</p>
      </div>
    </div>
    <div class="cta-watermark">USINE</div>
  </section>

</Layout>
