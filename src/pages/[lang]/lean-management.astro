---
import Layout from '../../layouts/Layout.astro';
import { BASE_PATH } from '../../config.js';
import { translations } from '../../i18n/ui.js';

export function getStaticPaths() {
  return [
    { params: { lang: 'fr' } },
    { params: { lang: 'en' } },
  ];
}

const { lang } = Astro.params;
const t = { ...translations['fr'], ...(translations[lang] || {}) };

const title = t['service_3.meta.title'];
const description = t['service_3.meta.description'];
const image = t['service_3.meta.image'];

const faqs = [
  {
    q: t['service_3.faq.1.q'],
    a: t['service_3.faq.1.a']
  },
  {
    q: t['service_3.faq.2.q'],
    a: t['service_3.faq.2.a']
  },
  {
    q: t['service_3.faq.3.q'],
    a: t['service_3.faq.3.a']
  },
  {
    q: t['service_3.faq.4.q'],
    a: t['service_3.faq.4.a']
  },
  {
    q: t['service_3.faq.5.q'],
    a: t['service_3.faq.5.a']
  }
];

const arrowSvg = `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
  <line x1="5" y1="12" x2="19" y2="12"></line>
  <polyline points="12 5 19 12 12 19"></polyline>
</svg>`;
---

<Layout lang={lang} title={title} description={description} image={image}>

  <!-- HERO SECTION -->
  <section class="service-hero">
    <div class="container mt-5">

      <h1>{t['service_3.hero.title']}</h1>
      <p>{t['service_3.hero.subtitle']}</p>
      <div class="mt-4">
        <a href={`${BASE_PATH}/${lang}/contact/`} class="btn btn-primary">{t['service_3.hero.cta']}</a>
      </div>
    </div>
  </section>

  <!-- DETAILS SECTION -->
  <section class="service-details p-0 mt-0 mb-0">
    <div class="split-section align-items-stretch">
      <div class="split-left pt-5rem pb-5rem bg-transparent">
        <div class="split-content-left">
        <h2 class="display-5 fw-bold mb-4 lh-sm">{t['service_3.details.title']}</h2>
        <p class="fs-5 opacity-75 lh-base mb-4" set:html={t['service_3.details.p1']}></p>
        <p class="fs-5 opacity-75 lh-base mb-5">{t['service_3.details.p2']}</p>

        <div class="service-quote">
          <p>{t['service_3.quote.text']}</p>
          <div class="quote-author">{t['service_3.quote.author']}</div>
        </div>

        <a href={`${BASE_PATH}/${lang}/contact/`} class="btn-dark mt-3">
          {t['service_1.details.cta']}
        </a>
        </div>
      </div>
      
      <div class="split-right pt-5rem pb-5rem bg-light">
        <div class="split-content-right d-flex flex-column justify-content-start">
          <div class="service-details-card bg-transparent py-0">
          <h3>{t['service_1.features.title']}</h3>
          <ul class="service-details-list">
            <li>
              <svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              <div>
                <h4>{t['service_3.features.1.title']}</h4>
                <p>{t['service_3.features.1.desc']}</p>
              </div>
            </li>
            <li>
              <svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              <div>
                <h4>{t['service_3.features.2.title']}</h4>
                <p>{t['service_3.features.2.desc']}</p>
              </div>
            </li>
            <li>
              <svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              <div>
                <h4>{t['service_3.features.3.title']}</h4>
                <p>{t['service_3.features.3.desc']}</p>
              </div>
            </li>
            <li>
              <svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              <div>
                <h4>{t['service_3.features.4.title']}</h4>
                <p>{t['service_3.features.4.desc']}</p>
              </div>
            </li>
          </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ SECTION -->
  <section id="faq">
    <div class="container grid-2 align-items-start gap-5">
      <div>
        <span class="section-tag section-tag-teal text-accent small text-uppercase">{t['service_1.faq.tag']}</span>
        <h2 class="display-4 fw-bold my-4 lh-sm" set:html={t['service_1.faq.title']}></h2>
        <p class="fs-5 opacity-75 lh-base">{t['service_3.faq.subtitle']}</p>
      </div>
      <div class="faq-list">
        {faqs.map((faq, index) => (
          <div class="faq-item">
            <button class="faq-question">
              <span class="text-accent me-4 fs-6">{(index + 1).toString().padStart(2, '0')}.</span>
              <span set:html={faq.q} class="flex-grow-1"></span>
              <span class="faq-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12h14"/></svg></span>
            </button>
            <div class="faq-answer">
              <p set:html={faq.a} class="opacity-75 ps-5 mt-n1 pb-4"></p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA SECTION -->
  <section class="service-cta">
    <div class="container">
      <h2>{t['service_1.cta.title']}</h2>
      <p class="fs-5 opacity-75 mx-auto mb-5 lh-base">{t['service_3.cta.subtitle']}</p>
      <a href={`${BASE_PATH}/${lang}/contact/`} class="btn-dark">{t['service_1.cta.button']} <span class="btn-arrow" set:html={arrowSvg}></span></a>
    </div>
  </section>

</Layout>
