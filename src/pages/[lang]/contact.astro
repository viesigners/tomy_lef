---
import Layout from '../../layouts/Layout.astro';
import { BASE_PATH } from '../../config.js';
import { translations } from '../../i18n/ui.js';

export function getStaticPaths() {
  return [
    { params: { lang: 'fr' } },
    { params: { lang: 'en' } },
  ];
}

const { lang } = Astro.params;
const t = { ...translations['fr'], ...(translations[lang] || {}) };

const title = "Contact | V2R Consulting";
const description = "Contactez V2R Consulting pour transformer votre entreprise manufacturière.";
---

<Layout lang={lang} title={title} description={description}>

  <!-- HERO SECTION -->
  <section class="service-hero">
    <div class="container mt-5">

      <h1 set:html={t['contact.hero.title'] || "Contactez-nous"}></h1>
      <p>{t['contact.hero.subtitle'] || "Prêt à libérer le potentiel de votre usine ? Parlez-nous de votre projet."}</p>
    </div>
  </section>

  <!-- CONTACT SECTION -->
  <section class="service-details">
    <div class="container grid-2" style="align-items: flex-start; gap: 4rem;">
      <div class="service-split-left">
        <span class="section-tag section-tag-teal" style="color: var(--accent-color); font-size: 0.8rem; letter-spacing: 2px; text-transform: uppercase; display: block; margin-bottom: 1rem;">NOUS JOINDRE</span>
        <h2 style="font-size: clamp(2rem, 4vw, 3.5rem); margin-bottom: 2rem; color: var(--text-dark); line-height: 1.1;">
          Discutons de <span style="color: #94A3B8;">votre projet</span>
        </h2>
        <p style="font-size: 1.15rem; color: #4b5563; line-height: 1.6; margin-bottom: 3rem;">
          Accès direct à nos experts. Nous maintenons une stricte confidentialité pour toutes les demandes et mandats.
        </p>
        
        <ul class="contact-info-list" style="margin-top: 3rem; list-style: none; padding: 0;">
          <li style="display: flex; align-items: flex-start; gap: 1.5rem; margin-bottom: 2rem;">
            <div style="width: 60px; height: 60px; border: 1px solid #e2e8f0; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
              <svg style="width: 24px; height: 24px; color: var(--accent-color);" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
            </div>
            <div>
              <span style="font-size: 0.8rem; text-transform: uppercase; letter-spacing: 1px; color: #94A3B8; font-weight: 600;">LIGNE DIRECTE</span><br/>
              <strong style="font-size: 1.5rem; color: var(--text-dark);">+1 581-502-1115</strong><br/>
              <span style="color: #64748b; font-size: 0.95rem;">Lun-Ven / 9h-17h</span>
            </div>
          </li>
          <li style="display: flex; align-items: flex-start; gap: 1.5rem; margin-bottom: 2rem;">
            <div style="width: 60px; height: 60px; border: 1px solid #e2e8f0; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
              <svg style="width: 24px; height: 24px; color: var(--accent-color);" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.243-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <div>
              <span style="font-size: 0.8rem; text-transform: uppercase; letter-spacing: 1px; color: #94A3B8; font-weight: 600;">BUREAU PRINCIPAL</span><br/>
              <strong style="font-size: 1.5rem; color: var(--text-dark);">Québec, QC, Canada</strong><br/>
              <span style="color: #64748b; font-size: 0.95rem;">Hub d'innovation</span>
            </div>
          </li>
        </ul>
      </div>
      
      <div class="service-split-right">
        <div class="contact-form-wrapper" style="background-color: #f5f7fa; padding: 4rem;">
          <h3 style="font-size: 2.2rem; color: #0f172a !important; margin-bottom: 3rem; letter-spacing: -0.03em;">Envoyez-nous un message</h3>
          <form action="#" method="POST" style="background: transparent; padding: 0; border: none;">
            <div class="form-row">
              <div class="form-group">
                <label for="first-name">PRÉNOM *</label>
                <input type="text" id="first-name" name="first-name" class="form-control-minimal" required>
              </div>
              <div class="form-group">
                <label for="last-name">NOM DE FAMILLE *</label>
                <input type="text" id="last-name" name="last-name" class="form-control-minimal" required>
              </div>
            </div>
            <div class="form-row">
              <div class="form-group">
                <label for="email">COURRIEL *</label>
                <input type="email" id="email" name="email" class="form-control-minimal" required>
              </div>
              <div class="form-group">
                <label for="phone">TÉLÉPHONE</label>
                <input type="tel" id="phone" name="phone" class="form-control-minimal">
              </div>
            </div>
            <div class="form-group" style="margin-top: 2rem;">
              <label for="message">MESSAGE</label>
              <textarea id="message" name="message" class="form-control-minimal" rows="2" required></textarea>
            </div>
            <button type="submit" class="btn btn-primary" style="margin-top: 2rem; padding: 1.2rem 2.5rem; font-size: 0.95rem; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; border-radius: 0 !important; background-color: #5C9EAA !important; border-color: #5C9EAA !important; color: #ffffff !important;">
              ENVOYER LE MESSAGE
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>

</Layout>

<style>
  .contact-form-wrapper .form-row {
    display: flex;
    gap: 2rem;
    margin-bottom: 2.5rem;
  }
  
  .contact-form-wrapper .form-group {
    flex: 1;
    display: flex;
    flex-direction: column;
  }
  
  .contact-form-wrapper label {
    font-size: 0.8rem;
    font-weight: 600;
    color: #64748b;
    letter-spacing: 1px;
    margin-bottom: 0.5rem;
  }
  
  .contact-form-wrapper .form-control-minimal {
    width: 100%;
    padding: 0.5rem 0;
    background: transparent;
    border: none;
    border-bottom: 1px solid #cbd5e1;
    color: var(--text-dark);
    font-size: 1rem;
    font-family: inherit;
    transition: border-color 0.3s;
  }
  
  .contact-form-wrapper .form-control-minimal:focus {
    outline: none;
    border-bottom-color: var(--accent-color);
  }
  
  @media (max-width: 768px) {
    .contact-form-wrapper .form-row {
      flex-direction: column;
      gap: 2.5rem;
    }
  }
</style>
