---
import Layout from '../../layouts/Layout.astro';
import { BASE_PATH } from '../../config.js';
import { translations, phoneNumber } from '../../i18n/ui.js';

export function getStaticPaths() {
  return [
    { params: { lang: 'fr' } },
    { params: { lang: 'en' } },
  ];
}

const { lang } = Astro.params;
const t = { ...translations['fr'], ...(translations[lang] || {}) };

const title = t['contact.meta.title'];
const description = t['contact.meta.description'];
---

<Layout lang={lang} title={title} description={description}>

  <!-- HERO SECTION -->
  <section class="service-hero">
    <div class="container mt-5">

      <h1 set:html={t['contact.hero.title']}></h1>
      <p>{t['contact.hero.subtitle']}</p>
    </div>
  </section>

  <!-- CONTACT SECTION -->
  <section class="service-details">
    <div class="container grid-2 align-items-start gap-5">
      <div class="service-split-left">
        <span class="section-tag section-tag-teal text-accent small text-uppercase d-block mb-3">{t['contact.info.tag']}</span>
        <h2 class="display-5 fw-bold mb-4 text-dark lh-sm" set:html={t['contact.info.title']}></h2>
        <p class="fs-5 text-secondary lh-base mb-5">
          {t['contact.info.desc']}
        </p>
        
        <ul class="contact-info-list mt-5 list-unstyled m-0 p-0">
          <li class="d-flex align-items-start gap-4 mb-4">
            <div class="border border-secondary-subtle d-flex align-items-center justify-content-center flex-shrink-0 p-3">
              <svg class="text-accent" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
            </div>
            <div>
              <span class="small text-uppercase text-secondary fw-semibold">{t['contact.info.label'] || t['contact.info.line1.label']}</span><br/>
              <a href={`tel:${phoneNumber.replace(/[\s-]/g, '')}`} class="fs-4 text-dark text-decoration-none fw-bold">{t['contact.info.line1.value']}</a><br/>
              <span class="text-secondary small">{t['contact.info.line1.hours']}</span>
            </div>
          </li>
          <li class="d-flex align-items-start gap-4 mb-4">
            <div class="border border-secondary-subtle d-flex align-items-center justify-content-center flex-shrink-0 p-3">
              <svg class="text-accent" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.243-4.243a8 8 0 1111.314 0z" />
                <path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <div>
              <span class="small text-uppercase text-secondary fw-semibold">{t['contact.info.line2.label']}</span><br/>
              <strong class="fs-4 text-dark">{t['contact.info.line2.value']}</strong><br/>
              <span class="text-secondary small">{t['contact.info.line2.desc']}</span>
            </div>
          </li>
        </ul>
      </div>
      
      <div class="service-split-right">
        <div class="contact-form-wrapper bg-light p-5">
          <h3 class="h2 text-dark mb-5">{t['contact.form.title']}</h3>
          <form action="#" method="POST" class="bg-transparent p-0 border-0">
            <div class="form-row">
              <div class="form-group">
                <label for="first-name">{t['contact.form.firstName']}</label>
                <input type="text" id="first-name" name="first-name" class="form-control-minimal" required>
              </div>
              <div class="form-group">
                <label for="last-name">{t['contact.form.lastName']}</label>
                <input type="text" id="last-name" name="last-name" class="form-control-minimal" required>
              </div>
            </div>
            <div class="form-row">
              <div class="form-group">
                <label for="email">{t['contact.form.email']}</label>
                <input type="email" id="email" name="email" class="form-control-minimal" required>
              </div>
              <div class="form-group">
                <label for="phone">{t['contact.form.phone']}</label>
                <input type="tel" id="phone" name="phone" class="form-control-minimal">
              </div>
            </div>
            <div class="form-group mt-4">
              <label for="message">{t['contact.form.message']}</label>
              <textarea id="message" name="message" class="form-control-minimal" rows="2" required></textarea>
            </div>
            <button type="submit" class="btn btn-primary mt-4 py-3 px-5 fw-bold text-uppercase rounded-0">
              {t['contact.form.submit']}
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>

</Layout>

<style>
  .contact-form-wrapper .form-row {
    display: flex;
    gap: 2rem;
    margin-bottom: 2.5rem;
  }
  
  .contact-form-wrapper .form-group {
    flex: 1;
    display: flex;
    flex-direction: column;
  }
  
  .contact-form-wrapper label {
    font-size: 0.8rem;
    font-weight: 600;
    color: #64748b;
    letter-spacing: 1px;
    margin-bottom: 0.5rem;
  }
  
  .contact-form-wrapper .form-control-minimal {
    width: 100%;
    padding: 0.5rem 0;
    background: transparent;
    border: none;
    border-bottom: 1px solid #cbd5e1;
    color: var(--text-dark);
    font-size: 1rem;
    font-family: inherit;
    transition: border-color 0.3s;
  }
  
  .contact-form-wrapper .form-control-minimal:focus {
    outline: none;
    border-bottom-color: var(--accent-color);
  }
  
  @media (max-width: 768px) {
    .contact-form-wrapper .form-row {
      flex-direction: column;
      gap: 2.5rem;
    }
  }
</style>
