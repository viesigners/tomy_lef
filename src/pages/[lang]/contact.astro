---
import Layout from '../../layouts/Layout.astro';
import { BASE_PATH } from '../../config.js';
import { translations } from '../../i18n/ui.js';

export function getStaticPaths() {
  return [
    { params: { lang: 'fr' } },
    { params: { lang: 'en' } },
  ];
}

const { lang } = Astro.params;
const t = { ...translations['fr'], ...(translations[lang] || {}) };

const title = "Contact | V2R Consulting";
const description = "Contactez V2R Consulting pour transformer votre entreprise manufacturière.";
---

<Layout lang={lang} title={title} description={description}>

  <!-- HERO SECTION -->
  <section class="service-hero">
    <div class="container">
      <span class="service-hero-tag">CONTACT</span>
      <h1 set:html={t['contact.hero.title'] || "Contactez-nous"}></h1>
      <p>{t['contact.hero.subtitle'] || "Prêt à libérer le potentiel de votre usine ? Parlez-nous de votre projet."}</p>
    </div>
  </section>

  <!-- CONTACT SECTION -->
  <section class="service-details">
    <div class="container grid-2" style="align-items: flex-start; gap: 4rem;">
      <div class="service-split-left">
        <h2 style="font-size: clamp(2rem, 4vw, 3rem); margin-bottom: 2rem; color: var(--text-color);">
          {t['contact.info.title'] || "Nos coordonnées"}
        </h2>
        
        <ul class="contact-info-list" style="margin-top: 3rem;">
          <li>
            <svg class="contact-info-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <div>
              <strong>{t['contact.info.phone.label'] || "Téléphone"}</strong><br/>
              <a href="tel:+15815021115" style="color: var(--text-color); opacity: 0.8; text-decoration: none;">+1 581-502-1115</a>
            </div>
          </li>
          <li>
            <svg class="contact-info-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <div>
              <strong>Courriel</strong><br/>
              <a href="mailto:info@v2rconsulting.com" style="color: var(--text-color); opacity: 0.8; text-decoration: none;">info@v2rconsulting.com</a>
            </div>
          </li>
          <li>
            <svg class="contact-info-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.243-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <div>
              <strong>Adresse</strong><br/>
              <span style="opacity: 0.8;">Québec, QC, Canada</span>
            </div>
          </li>
        </ul>
      </div>
      
      <div class="service-split-right">
        <form class="contact-form" action="#" method="POST" style="background-color: var(--bg-color); border: 1px solid rgba(255,255,255,0.1); padding: 3rem; border-radius: var(--radius-card);">
          <div class="form-group" style="margin-bottom: 1.5rem;">
            <label for="name" style="display: block; margin-bottom: 0.5rem; color: #fff;">Nom complet</label>
            <input type="text" id="name" name="name" class="form-control" required style="width: 100%; padding: 1rem; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); color: #fff; border-radius: 4px;">
          </div>
          <div class="form-group" style="margin-bottom: 1.5rem;">
            <label for="email" style="display: block; margin-bottom: 0.5rem; color: #fff;">Adresse courriel</label>
            <input type="email" id="email" name="email" class="form-control" required style="width: 100%; padding: 1rem; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); color: #fff; border-radius: 4px;">
          </div>
          <div class="form-group" style="margin-bottom: 1.5rem;">
            <label for="subject" style="display: block; margin-bottom: 0.5rem; color: #fff;">Sujet</label>
            <input type="text" id="subject" name="subject" class="form-control" required style="width: 100%; padding: 1rem; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); color: #fff; border-radius: 4px;">
          </div>
          <div class="form-group" style="margin-bottom: 2rem;">
            <label for="message" style="display: block; margin-bottom: 0.5rem; color: #fff;">Message</label>
            <textarea id="message" name="message" class="form-control" rows="5" required style="width: 100%; padding: 1rem; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); color: #fff; border-radius: 4px; resize: vertical;"></textarea>
          </div>
          <button type="submit" class="btn btn-primary" style="width: 100%; padding: 1.2rem; font-size: 1.1rem; font-weight: 700; text-transform: uppercase;">
            Envoyer le message
          </button>
        </form>
      </div>
    </div>
  </section>

</Layout>
