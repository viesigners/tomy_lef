---
import Layout from '../../layouts/Layout.astro';
import { BASE_PATH } from '../../config.js';
import { translations } from '../../i18n/ui.js';

export function getStaticPaths() {
  return [
    { params: { lang: 'fr' } },
    { params: { lang: 'en' } },
  ];
}

const { lang } = Astro.params;
const t = { ...translations['fr'], ...(translations[lang] || {}) };

const title = "Industrie 4.0 | V2R Consulting";
const description = "Cartographie par la méthode Problem first et intégration de l'Intelligence Artificielle pour optimiser vos opérations.";

const faqs = [
  {
    q: "Par où commencer notre transition vers l'Industrie 4.0?",
    a: "Nous commençons toujours par un diagnostic numérique pour identifier les processus qui bénéficieront le plus rapidement et le plus rentablement de l'automatisation."
  },
  {
    q: "Faut-il remplacer tous nos équipements actuels?",
    a: "Pas nécessairement. De nombreux équipements existants peuvent être connectés grâce à des capteurs (IoT) pour récolter des données précieuses."
  },
  {
    q: "Comment gérer la résistance au changement?",
    a: "L'accompagnement humain est essentiel. Nous impliquons vos équipes dès le début pour démystifier la technologie et démontrer comment elle facilitera leur travail."
  },
  {
    q: "Qu'est-ce qu'un système d'exécution des fabrications (MES)?",
    a: "C'est un logiciel qui connecte vos équipements à vos systèmes de gestion (ERP) pour un suivi de la production et de la performance en temps réel."
  },
  {
    q: "La numérisation est-elle sécuritaire?",
    a: "La cybersécurité est intégrée dans toutes nos recommandations pour protéger vos données opérationnelles et assurer la continuité de vos affaires."
  }
];

const arrowSvg = `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
  <line x1="5" y1="12" x2="19" y2="12"></line>
  <polyline points="12 5 19 12 12 19"></polyline>
</svg>`;
---

<Layout lang={lang} title={title} description={description}>

  <!-- HERO SECTION -->
  <section class="service-hero">
    <div class="container">

      <h1>Industrie 4.0</h1>
      <p>Entrez dans l'ère de la production intelligente et optimisez vos opérations grâce aux données et à l'intelligence artificielle.</p>
    </div>
  </section>

  <!-- DETAILS SECTION -->
  <section class="service-details p-0 mt-0 mb-0">
    <div class="split-section" style="align-items: stretch;">
      <div class="split-left pt-5rem pb-5rem" style="background-color: transparent;">
        <div class="split-content-left">
        <h2 style="font-size: clamp(2rem, 4vw, 3.5rem); margin-bottom: 2rem; line-height: 1.1; max-width: 600px;">La nouvelle génération de production.</h2>
        <p style="font-size: 1.15rem; opacity: 0.8; line-height: 1.6; margin-bottom: 1.5rem;">
          Nous appliquons la méthode <strong>Problem First</strong> pour comprendre précisément vos goulots d'étranglement avant d'introduire toute technologie. L'intégration de l'IA n'est pertinente que si elle règle un problème coûteux.
        </p>
        <p style="font-size: 1.15rem; opacity: 0.8; line-height: 1.6; margin-bottom: 2rem;">
          Que vous cherchiez des "quick wins" grâce à une approche hybride ou une intégration clé en main de capteurs IoT, nous connectons votre plancher à vos objectifs financiers.
        </p>

        <div class="service-quote">
          <p>"Avant V2R, nous nagions dans les données sans savoir quoi en faire. Aujourd'hui, nos tableaux de bord nous dictent exactement où agir pour optimiser notre production."</p>
          <div class="quote-author">Alain Côté, Président, IndusTech Solutions</div>
        </div>

        <a href={`${BASE_PATH}/${lang}/contact/`} class="btn-dark" style="margin-top: 1rem;">
          DISCUTER D'UN PROJET
        </a>
        </div>
      </div>
      
      <div class="split-right pt-5rem pb-5rem" style="background-color: #f5f7fa;">
        <div class="split-content-right" style="display: flex; flex-direction: column; justify-content: flex-start;">
          <div class="service-details-card" style="background: transparent; padding-top: 0; padding-bottom: 0;">
          <h3>Ce que ça inclut :</h3>
          <ul class="service-details-list">
            <li>
              <svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              <div>
                <h4>Audit de maturité numérique</h4>
                <p>Évaluation de votre infrastructure de données actuelle (ERP, MES, automates).</p>
              </div>
            </li>
            <li>
              <svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              <div>
                <h4>Cartographie Problem First</h4>
                <p>Identification des flux opérationnels et des freins majeurs à la productivité.</p>
              </div>
            </li>
            <li>
              <svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              <div>
                <h4>Maintenance prédictive IA</h4>
                <p>Intégration d'algorithmes pour réduire les arrêts non planifiés.</p>
              </div>
            </li>
            <li>
              <svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              <div>
                <h4>Déploiement hybride</h4>
                <p>Solutions adaptées à vos ressources internes pour un ROI rapide (6 à 12 mois).</p>
              </div>
            </li>
          </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ SECTION -->
  <section id="faq" style="background-color: var(--bg-color); color: var(--text-color); padding: 8rem 0;">
    <div class="container grid-2" style="align-items: flex-start; gap: 4rem;">
      <div>
        <span class="section-tag section-tag-teal" style="color: var(--accent-color); font-size: 0.8rem; letter-spacing: 2px; text-transform: uppercase;">FAQ'S</span>
        <h2 style="font-size: clamp(3rem, 5vw, 4.5rem); line-height: 1.1; margin: 2rem 0; color: var(--text-color) !important;">
          Réponses à<br />
          <span style="color: rgba(255,255,255,0.4);">vos<br />questions.</span>
        </h2>
        <p style="font-size: 1.15rem; opacity: 0.8; line-height: 1.6; max-width: 400px;">Tout ce que vous devez savoir pour entamer votre transformation vers l'Industrie 4.0.</p>
      </div>
      <div class="faq-list" style="border-top: 1px solid rgba(255,255,255,0.1);">
        {faqs.map((faq, index) => (
          <div class="faq-item" style="border-bottom: 1px solid rgba(255,255,255,0.1);">
            <button class="faq-question" style="color: var(--text-color);">
              <span style="color: var(--accent-color); margin-right: 1.5rem; font-size: 1rem;">{(index + 1).toString().padStart(2, '0')}.</span>
              <span set:html={faq.q} style="flex: 1;"></span>
              <span class="faq-icon" style="font-size: 1.2rem; font-weight: 300; width: 36px; height: 36px; border: 1px solid rgba(255,255,255,0.2); display: flex; align-items: center; justify-content: center; opacity: 0.7;">+</span>
            </button>
            <div class="faq-answer">
              <p set:html={faq.a} style="opacity: 0.7; padding-left: 3rem; margin-top: -0.5rem; padding-bottom: 1.5rem;"></p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA SECTION -->
  <section class="service-cta">
    <div class="container">
      <h2>Augmentation de la performance garantie!</h2>
      <p style="font-size: 1.15rem; opacity: 0.8; max-width: 600px; margin: 0 auto 2.5rem; line-height: 1.6;">Ne laissez pas vos concurrents prendre l'avantage technologique. Entamez dès aujourd'hui votre virage numérique et exploitez tout le potentiel de vos données pour optimiser vos opérations.</p>
      <a href={`${BASE_PATH}/${lang}/contact/`} class="btn-dark">Réserver un diagnostic V2R <span class="btn-arrow" set:html={arrowSvg}></span></a>
    </div>
  </section>

</Layout>
