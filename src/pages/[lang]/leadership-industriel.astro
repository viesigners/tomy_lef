---
import Layout from '../../layouts/Layout.astro';
import { BASE_PATH } from '../../config.js';
import { translations } from '../../i18n/ui.js';

export function getStaticPaths() {
  return [
    { params: { lang: 'fr' } },
    { params: { lang: 'en' } },
  ];
}

const { lang } = Astro.params;
const t = { ...translations['fr'], ...(translations[lang] || {}) };

const title = "Leadership industriel | V2R Consulting";
const description = "Implantation d'une philosophie managériale assumée pour briser les silos et responsabiliser les équipes sur le plancher.";
---

<Layout lang={lang} title={title} description={description}>

  <!-- HERO SECTION -->
  <section class="service-hero">
    <div class="container">
      <span class="service-hero-tag">SERVICE</span>
      <h1>Leadership industriel</h1>
      <p>Transformez vos superviseurs en véritables leaders opérationnels capables d'engager leurs équipes.</p>
    </div>
  </section>

  <!-- DETAILS SECTION -->
  <section class="service-details">
    <div class="container grid-2" style="align-items: center; gap: 4rem;">
      <div class="service-split-left">
        <h2 style="font-size: clamp(2rem, 4vw, 3.5rem); margin-bottom: 2rem; line-height: 1.1; max-width: 600px;">La nouvelle génération de leaders.</h2>
        <p style="font-size: 1.15rem; opacity: 0.8; line-height: 1.6; margin-bottom: 1.5rem;">
          L'usine de demain ne se pilote pas depuis un bureau. Elle nécessite des leaders présents sur le plancher, capables d'inspirer et de responsabiliser.
        </p>
        <p style="font-size: 1.15rem; opacity: 0.8; line-height: 1.6; margin-bottom: 3rem;">
          Nous vous aidons à implanter une philosophie managériale assumée pour briser les silos interdépartementaux, redonner du pouvoir à vos équipes terrain et installer une culture de responsabilisation forte.
        </p>
        <a href={`${BASE_PATH}/${lang}/contact/`} class="btn-light-solid" style="margin-top: 1rem;">
          DISCUTER D'UN PROJET
        </a>
      </div>
      
      <div class="service-split-right">
        <div class="service-details-card">
          <h3>Ce que ça inclut :</h3>
          <ul class="qualification-list qualification-list--yes service-details-list">
            <li>
              <div>
                <strong>Coaching de supervision</strong>
                <span>Accompagnement terrain de vos superviseurs pour asseoir leur autorité naturelle.</span>
              </div>
            </li>
            <li>
              <div>
                <strong>Bris des silos</strong>
                <span>Mise en place de rituels transversaux entre production, maintenance et qualité.</span>
              </div>
            </li>
            <li>
              <div>
                <strong>Responsabilisation (Empowerment)</strong>
                <span>Délégation structurée pour rendre vos équipes plus autonomes.</span>
              </div>
            </li>
            <li>
              <div>
                <strong>Culture de résultat</strong>
                <span>Implantation d'une dynamique où chaque membre se sent propriétaire de sa performance.</span>
              </div>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA SECTION -->
  <section class="service-cta">
    <div class="container">
      <h2>Augmentation de la performance garantie!</h2>
      <a href={`${BASE_PATH}/${lang}/contact/`} class="btn-dark">REJOINDRE VIESIGNERS</a>
    </div>
  </section>

</Layout>
