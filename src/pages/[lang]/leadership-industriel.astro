---
import Layout from '../../layouts/Layout.astro';
import { BASE_PATH } from '../../config.js';
import { translations } from '../../i18n/ui.js';

export function getStaticPaths() {
  return [
    { params: { lang: 'fr' } },
    { params: { lang: 'en' } },
  ];
}

const { lang } = Astro.params;
const t = { ...translations['fr'], ...(translations[lang] || {}) };

const title = "Leadership industriel | V2R Consulting";
const description = "Développement du courage managérial, scripts de gestion de conflits et synergie d'équipe.";

const faqs = [
  {
    q: "Qu'est-ce que le leadership opérationnel?",
    a: "C'est la capacité pour un superviseur de guider son équipe directement sur le plancher, en assurant la fluidité des opérations et le respect des standards."
  },
  {
    q: "Mes superviseurs actuels peuvent-ils devenir de meilleurs leaders?",
    a: "Tout à fait. Le leadership s'apprend. Avec la bonne formation et des outils concrets comme nos scripts de gestion de conflits, ils prendront confiance."
  },
  {
    q: "Comment réduire le roulement de personnel?",
    a: "Un leadership fort et empathique crée un environnement de travail où les employés se sentent valorisés et compris, ce qui fidélise grandement la main-d'œuvre."
  },
  {
    q: "En quoi consistent les rituels de communication?",
    a: "Ce sont des rencontres courtes et structurées (comme des réunions quotidiennes de 10 minutes) pour aligner l'équipe sur les objectifs du jour et lever les obstacles."
  },
  {
    q: "Faites-vous du coaching sur le terrain?",
    a: "Oui, c'est au cœur de notre approche. Nous accompagnons vos superviseurs dans leur quotidien pour ancrer les bonnes pratiques directement en situation réelle."
  }
];

const arrowSvg = `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
  <line x1="5" y1="12" x2="19" y2="12"></line>
  <polyline points="12 5 19 12 12 19"></polyline>
</svg>`;
---

<Layout lang={lang} title={title} description={description}>

  <!-- HERO SECTION -->
  <section class="service-hero">
    <div class="container">

      <h1>Leadership industriel</h1>
      <p>Transformez vos superviseurs en véritables leaders opérationnels capables d'engager leurs équipes.</p>
    </div>
  </section>

  <!-- DETAILS SECTION -->
  <section class="service-details p-0 mt-0 mb-0">
    <div class="split-section" style="align-items: stretch;">
      <div class="split-left pt-5rem pb-5rem" style="background-color: transparent;">
        <div class="split-content-left">
        <h2 style="font-size: clamp(2rem, 4vw, 3.5rem); margin-bottom: 2rem; line-height: 1.1; max-width: 600px;">La nouvelle génération de leaders.</h2>
        <p style="font-size: 1.15rem; opacity: 0.8; line-height: 1.6; margin-bottom: 1.5rem;">
          L'usine de demain ne se pilote pas depuis un bureau. Elle nécessite des leaders présents sur le plancher, capables d'inspirer et de responsabiliser.
        </p>
        <p style="font-size: 1.15rem; opacity: 0.8; line-height: 1.6; margin-bottom: 2rem;">
          Notre approche pragmatique fournit des outils clés en main (routines de plancher, scripts de gestion de conflits) et un accompagnement sur mesure pour que chaque superviseur prenne pleinement sa place.
        </p>

        <div class="service-quote">
          <p>"Nos superviseurs étaient techniquement excellents mais hésitaient à gérer les écarts de conduite. V2R leur a donné le courage managérial qui a changé la dynamique de l'usine."</p>
          <div class="quote-author">Luc Deschênes, Directeur Général, NovaSteel</div>
        </div>

        <a href={`${BASE_PATH}/${lang}/contact/`} class="btn-dark" style="margin-top: 1rem;">
          DISCUTER D'UN PROJET
        </a>
        </div>
      </div>
      
      <div class="split-right pt-5rem pb-5rem" style="background-color: #f5f7fa;">
        <div class="split-content-right" style="display: flex; flex-direction: column; justify-content: flex-start;">
          <div class="service-details-card" style="background: transparent; padding-top: 0; padding-bottom: 0;">
          <h3>Ce que ça inclut :</h3>
          <ul class="service-details-list">
            <li>
              <svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              <div>
                <h4>Coaching de supervision</h4>
                <p>Accompagnement terrain de vos superviseurs pour asseoir leur autorité naturelle.</p>
              </div>
            </li>
            <li>
              <svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              <div>
                <h4>Bris des silos</h4>
                <p>Mise en place de rituels transversaux entre production, maintenance et qualité.</p>
              </div>
            </li>
            <li>
              <svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              <div>
                <h4>Responsabilisation (Empowerment)</h4>
                <p>Délégation structurée pour rendre vos équipes plus autonomes.</p>
              </div>
            </li>
            <li>
              <svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              <div>
                <h4>Culture de résultat</h4>
                <p>Implantation d'une dynamique où chaque membre se sent propriétaire de sa performance.</p>
              </div>
            </li>
          </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ SECTION -->
  <section id="faq" style="background-color: var(--bg-color); color: var(--text-color); padding: 8rem 0;">
    <div class="container grid-2" style="align-items: flex-start; gap: 4rem;">
      <div>
        <span class="section-tag section-tag-teal" style="color: var(--accent-color); font-size: 0.8rem; letter-spacing: 2px; text-transform: uppercase;">FAQ'S</span>
        <h2 style="font-size: clamp(3rem, 5vw, 4.5rem); line-height: 1.1; margin: 2rem 0; color: var(--text-color) !important;">
          Réponses à<br />
          <span style="color: rgba(255,255,255,0.4);">vos<br />questions.</span>
        </h2>
        <p style="font-size: 1.15rem; opacity: 0.8; line-height: 1.6; max-width: 400px;">Tout ce que vous devez savoir pour entamer votre transformation en matière de leadership.</p>
      </div>
      <div class="faq-list" style="border-top: 1px solid rgba(255,255,255,0.1);">
        {faqs.map((faq, index) => (
          <div class="faq-item" style="border-bottom: 1px solid rgba(255,255,255,0.1);">
            <button class="faq-question" style="color: var(--text-color);">
              <span style="color: var(--accent-color); margin-right: 1.5rem; font-size: 1rem;">{(index + 1).toString().padStart(2, '0')}.</span>
              <span set:html={faq.q} style="flex: 1;"></span>
              <span class="faq-icon" style="font-size: 1.2rem; font-weight: 300; width: 36px; height: 36px; border: 1px solid rgba(255,255,255,0.2); display: flex; align-items: center; justify-content: center; opacity: 0.7;">+</span>
            </button>
            <div class="faq-answer">
              <p set:html={faq.a} style="opacity: 0.7; padding-left: 3rem; margin-top: -0.5rem; padding-bottom: 1.5rem;"></p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA SECTION -->
  <section class="service-cta">
    <div class="container">
      <h2>Augmentation de la performance garantie!</h2>
      <p style="font-size: 1.15rem; opacity: 0.8; max-width: 600px; margin: 0 auto 2.5rem; line-height: 1.6;">Le manque d'encadrement coûte cher en rétention et en efficacité. Équipez vos superviseurs dès aujourd'hui du courage managérial nécessaire pour bâtir une équipe engagée et performante.</p>
      <a href={`${BASE_PATH}/${lang}/contact/`} class="btn-dark">Réserver un diagnostic V2R <span class="btn-arrow" set:html={arrowSvg}></span></a>
    </div>
  </section>

</Layout>
