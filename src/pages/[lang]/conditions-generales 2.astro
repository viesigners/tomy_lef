---
import Layout from '../../layouts/Layout.astro';
import { translations } from '../../i18n/ui.js';
import { termsOfUseContent } from '../../i18n/ui.js';

export function getStaticPaths() {
  return [
    { params: { lang: 'fr' } },
    { params: { lang: 'en' } },
  ];
}

const { lang } = Astro.params;
const t = { ...translations['fr'], ...(translations[lang] || {}) };

const title = t['terms.meta.title'];
const description = t['terms.meta.description'];
const content = termsOfUseContent[lang] || termsOfUseContent['fr'];
---

<Layout lang={lang} title={title} description={description}>

  <!-- BANNER -->
  <section class="service-hero">
    <div class="container text-center">
      <h1>{t['terms.title']}</h1>
    </div>
  </section>

  <!-- CONTENT -->
  <section class="section-light py-5">
    <div class="container py-5">
      <div class="mx-auto" style="max-width: 760px;" set:html={content} />
    </div>
  </section>

</Layout>
